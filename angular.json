{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "ams-ng": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "",
            "sourceRoot": "src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:browser",
                    "options": {
                        "outputPath": "dist",
                        "index": "src/index.html",
                        "main": "src/main.ts",
                        "polyfills": [
                            "zone.js"
                        ],
                        "tsConfig": "tsconfig.app.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "src/assets/",
                                "output": "/assets/"
                            },
                            {
                                "glob": "manifest.webmanifest",
                                "input": "src/",
                                "output": "/"
                            }
                        ],
                        "styles": [
                            "src/styles.scss"
                        ],
                        "scripts": [
                            "node_modules/jquery/dist/jquery.min.js",
                            "node_modules/jquery-ui-pack/jquery-ui.js",
                            "src/assets/js/paramquery/pqgrid.min.js"
                        ],
                        "budgets": [
                            {
                                "type": "initial",
                                "maximumWarning": "10mb",
                                "maximumError": "50mb"
                            },
                            {
                                "type": "anyComponentStyle",
                                "maximumWarning": "20kb",
                                "maximumError": "40kb"
                            }
                        ],
                        "allowedCommonJsDependencies": [
                            "lodash"
                        ]
                    },
                    "configurations": {
                        "production": {
                            "outputHashing": "all",
                            "serviceWorker": "ngsw-config.json",
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "10mb",
                                    "maximumError": "50mb"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "20kb",
                                    "maximumError": "40kb"
                                }
                            ]
                        },
                        "testing": {
                            "outputHashing": "none",
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true,
                            "fileReplacements": [
                                {
                                    "replace": "src/constants/environment.ts",
                                    "with": "src/constants/environment.test.ts"
                                }
                            ]
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true,
                            "fileReplacements": [
                                {
                                    "replace": "src/constants/environment.ts",
                                    "with": "src/constants/environment.dev.ts"
                                }
                            ]
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "options": {
                        "ssl": false,
                        "disableHostCheck": true,
                        "hmr": true,
                        "port": 4200,
                        "proxyConfig": "proxy.conf.json"
                    },
                    "configurations": {
                        "production": {
                            "buildTarget": "ams-ng:build:production"
                        },
                        "development": {
                            "buildTarget": "ams-ng:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "polyfills": [
                            "zone.js",
                            "zone.js/testing"
                        ],
                        "tsConfig": "tsconfig.spec.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "src/assets/",
                                "output": "/assets/"
                            }
                        ],
                        "styles": [
                            "src/styles.scss"
                        ],
                        "scripts": [
                            "node_modules/jquery/dist/jquery.min.js",
                            "node_modules/jquery-ui-pack/jquery-ui.js",
                            "src/assets/js/paramquery/pqgrid.min.js"
                        ]
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": false
    }
}
